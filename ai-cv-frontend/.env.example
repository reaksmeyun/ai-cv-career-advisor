# Base URL of the Python FastAPI backend (no trailing slash).
# Local dev:   http://localhost:8000
# Production:  your Hugging Face Space URL, e.g. https://USER-ai-cv-backend.hf.space
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Set to "true" to use built-in demo data instead of calling the backend.
# Handy for demoing the UI without running the Python service.
NEXT_PUBLIC_USE_MOCK=false

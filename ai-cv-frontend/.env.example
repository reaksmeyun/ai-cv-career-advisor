# Hugging Face token for AI inference — used SERVER-SIDE only.
# No NEXT_PUBLIC_ prefix, so it stays secret and is never sent to the browser.
HF_TOKEN=hf_your_token_here

# Optional: which model to call via Hugging Face Inference Providers.
MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct

# Set to "true" to use built-in demo data instead of calling the AI.
NEXT_PUBLIC_USE_MOCK=false

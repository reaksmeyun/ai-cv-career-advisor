# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

cat > .gitignore <<'EOF'
# Python virtual environments
.venv/
venv/
env/
ai-cv-backend/.venv/

# Python cache
__pycache__/
*.py[cod]
.pytest_cache/

# Environment variables
.env
.env.*
!.env.example

# Local AI models
*.gguf
*.bin
models/
model/

# Uploaded and temporary files
uploads/
temp/
tmp/
*.log

# Frontend
node_modules/
.next/
out/
dist/

# IDE and OS
.vscode/
.idea/
.DS_Store
EOF